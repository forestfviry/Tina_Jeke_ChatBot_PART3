<Window x:Class="switch_grid.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:switch_grid"
        mc:Ignorable="d"
        Title="CyberGuard" Height="450" Width="800"
        Background="#0D1117">

    <Grid>
        <!--start of parent grid-->

        <!-- LOGO GRID -->
        <Grid x:Name="logo_grid" Visibility="Visible" Background="#0D1117">
            <!--start of logo grid-->

            <ScrollViewer Height="300" Width="760" VerticalAlignment="Top" Margin="0,10,0,0"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock
                    x:Name="ascii_logo_box"
                    FontFamily="Consolas"
                    FontSize="4.5"
                    FontWeight="Bold"
                    Foreground="#FFFFFF"
                    HorizontalAlignment="Center"
                    TextAlignment="Left"
                    LineHeight="3.5"
                    LineStackingStrategy="BlockLineHeight"
                    xml:space="preserve">Parsing security system asset matrices...</TextBlock>
            </ScrollViewer>

            <Button
                Height="40"
                Width="200"
                Margin="0,345,0,0"
                Content="Start AI"
                Click="start_ai"
                Background="#58A6FF"
                Foreground="#0D1117"
                FontFamily="Consolas"
                FontWeight="Bold"
                BorderThickness="0"
                Cursor="Hand"
                IsDefault="True"/>

        </Grid>
        <!--end of logo grid-->

        <!-- USERNAME GRID -->
        <Grid x:Name="username_grid" Visibility="Hidden" Background="#0D1117">
            <!--start of username grid-->

            <TextBlock
                Text="Hello, What's your name?"
                FontFamily="Consolas"
                FontSize="14"
                FontWeight="Bold"
                Foreground="#58A6FF"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,0,0,120"/>

            <TextBox
                x:Name="user_name"
                Height="50"
                Width="400"
                Background="#21262D"
                Foreground="#E6EDF3"
                FontFamily="Consolas"
                FontSize="13"
                BorderBrush="#58A6FF"
                BorderThickness="1"
                Padding="10,0"
                CaretBrush="#58A6FF"/>

            <Button
                Height="50"
                Width="250"
                Margin="0,200,0,0"
                Content="Submit"
                Click="submit_name"
                Background="#58A6FF"
                Foreground="#0D1117"
                FontFamily="Consolas"
                FontWeight="Bold"
                BorderThickness="0"
                Cursor="Hand"
                IsDefault="True"/>

        </Grid>
        <!--end of username grid-->

        <!-- CHATS GRID -->
        <Grid x:Name="chats_grid" Visibility="Hidden" Background="#0D1117">
            <!--start of chats grid-->

            <ListView
                x:Name="chats_list"
                Height="250"
                Width="700"
                Margin="0,0,0,160"
                Background="#0D1117"
                Foreground="#E6EDF3"
                FontFamily="Consolas"
                FontSize="13"
                BorderBrush="#21262D"
                BorderThickness="1"/>

            <TextBox
                x:Name="question"
                Height="50"
                Width="300"
                Margin="0,250,400,0"
                Background="#21262D"
                Foreground="#E6EDF3"
                FontFamily="Consolas"
                FontSize="13"
                BorderBrush="#58A6FF"
                BorderThickness="1"
                Padding="10,0"
                CaretBrush="#58A6FF"/>

            <Button
                Height="50"
                Width="200"
                Margin="200,250,0,0"
                Content="send"
                Click="send_question"
                Background="#58A6FF"
                Foreground="#0D1117"
                FontFamily="Consolas"
                FontWeight="Bold"
                BorderThickness="0"
                Cursor="Hand"
                IsDefault="True"/>

        </Grid>
        <!--end of chats grid-->

        <!-- TASKS GRID -->
        <Grid x:Name="tasks_grid" Visibility="Hidden" Background="#0D1117">
            <!--start of tasks grid-->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#161B22" Padding="20,10">
                <TextBlock
                    Text="Task Manager — Cybersecurity To-Do"
                    FontFamily="Consolas"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="#58A6FF"/>
            </Border>

            <!-- Task list -->
            <ListView
                Grid.Row="1"
                x:Name="tasks_list"
                Background="#0D1117"
                Foreground="#E6EDF3"
                FontFamily="Consolas"
                FontSize="12"
                BorderBrush="#21262D"
                BorderThickness="1"
                Margin="10,10,10,0"/>

            <!-- Input row -->
            <Grid Grid.Row="2" Margin="10,10,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    x:Name="task_title"
                    Height="40"
                    Background="#21262D"
                    Foreground="#E6EDF3"
                    FontFamily="Consolas"
                    FontSize="12"
                    BorderBrush="#58A6FF"
                    BorderThickness="1"
                    Padding="8,0"
                    CaretBrush="#58A6FF"/>

                <TextBox
                    Grid.Column="2"
                    x:Name="task_description"
                    Height="40"
                    Background="#21262D"
                    Foreground="#E6EDF3"
                    FontFamily="Consolas"
                    FontSize="12"
                    BorderBrush="#58A6FF"
                    BorderThickness="1"
                    Padding="8,0"
                    CaretBrush="#58A6FF"/>

                <Button
                    Grid.Column="4"
                    Content="ADD TASK"
                    Height="40"
                    Background="#58A6FF"
                    Foreground="#0D1117"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="add_task"/>

            </Grid>

            <!-- Bottom buttons -->
            <Grid Grid.Row="3" Margin="10,8,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="COMPLETE"
                    Height="38"
                    Background="#00FF88"
                    Foreground="#0D1117"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="complete_task"/>

                <Button
                    Grid.Column="2"
                    Content="DELETE"
                    Height="38"
                    Background="#FF4444"
                    Foreground="#FFFFFF"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="delete_task"/>

                <Button
                    Grid.Column="4"
                    Content="BACK TO CHAT"
                    Height="38"
                    Background="#21262D"
                    Foreground="#E6EDF3"
                    FontFamily="Consolas"
                    BorderThickness="1"
                    BorderBrush="#58A6FF"
                    Cursor="Hand"
                    Click="back_to_chat"/>

            </Grid>

        </Grid>
        <!--end of tasks grid-->

    </Grid>
    <!--end of parent grid-->

</Window>